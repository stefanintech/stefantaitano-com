---
layout: base
title: Articles
description: 'Writing on ServiceNow, software development, and things worth sharing.'
pagination:
  data: collections.allPosts
  size: 8
  generatePageOnEmptyData: true
permalink: 'articles/{% if pagination.pageNumber >=1 %}page-{{ pagination.pageNumber + 1 }}/{% endif %}index.html'
---

<div class="wrapper">
  <header class="full | section" style="--spot-color: var(--color-secondary)">
    <div class="section__inner flow region" style="--region-space-top: var(--space-xl-2xl)">
      <h1 class="text-center" style="color: var(--color-light);">{{ title }}</h1>
    </div>

    {% svg "divider/edgy", null, "divider" %}
  </header>

  {% if pagination.items.length %}
    <custom-masonry layout="50-50">
      {% asyncEach item in pagination.items %}
        {% include "partials/card-blog.njk" %}
      {% endeach %}
    </custom-masonry>
  {% else %}
    <div class="prose wrapper flow region" style="--region-space-top: var(--space-l-xl)">
      <p>No articles published yet. When something is ready, it will show up here.</p>
    </div>
  {% endif %}

  {% set collectionToPaginate = collections.allPosts %}
  {% set metaKey = "blog" %}
  {% if collectionToPaginate.length > pagination.size %}
    {% include 'partials/pagination.njk' %}
  {% endif %}
</div>
